<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- v0.6 — sandbox désactivé pour dev rapide. Cartographer scan ~/Developer/* sans NSOpenPanel friction.
	     v1.0 hardening : re-activer sandbox + NSOpenPanel one-shot pour ~/Developer access. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- v0.6 (Cartographer Process spawn `gh` CLI) : besoin de permettre l'exécution de binaires externes.
	     Sans sandbox, c'est implicite. Avec sandbox, il faudra com.apple.security.inherit + signed gh binary. -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
</dict>
</plist>
